generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int       @id @default(autoincrement())
  nome      String    @db.VarChar(50)
  cargo     CargoEnum @default(PROFESSOR)
  email     String    @unique
  senha     String
  idExterno String    @unique @default(uuid()) @map("id_externo")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("usuarios")
}

enum CargoEnum {
  PROFESSOR
  COORDENADOR
  TECNICO
}
