generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id            Int       @id @default(autoincrement())
  nome          String    @db.VarChar(50)
  cargo         CargoEnum @default(PROFESSOR)
  email         String    @unique
  senha         String
  idExterno     String    @unique @default(uuid()) @map("id_externo")
  instituicaoId Int       @map("instituicao_id")
  ativo         Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  VinculoInstituicao        InstituicaoEnsino @relation(fields: [instituicaoId], references: [id])
  LaboratoriosAdministrados Laboratorio[]
  ManutencoesSolicitadas    Manutencao[]      @relation("UsuarioSolicitou")
  ManutencoesFeitas         Manutencao[]      @relation("TecnicoResponsavel")

  @@map("usuarios")
}

model InstituicaoEnsino {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(50)
  cnpj      String   @unique
  latitude  Float
  longitude Float
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  UsuariosVinculados Usuario[]

  @@map("intituicoes_ensino")
}

model Laboratorio {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(50)
  descricao     String?
  responsavelId String      @map("responsavel_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  Responsavel          Usuario      @relation(fields: [responsavelId], references: [idExterno])
  ManutencoesRecebidas Manutencao[]

  @@map("laboratorios")
}

model Manutencao {
  id                      Int              @id @default(autoincrement())
  prazo                   DateTime
  status                  StatusManutencao @default(SOLICITADA)
  tipo                    TipoManutencao   @default(CORRETIVA)
  descricaoSolicitada     String           @db.Text
  descricaoAposFinalizada String?          @db.Text
  usuarioSolicitacaoId    Int              @map("usuario_solicitacao_id")
  tecnicoResponsavelId    Int              @map("tecnico_responsavel_id")
  laboratorioId           Int              @map("laboratorio_id")
  dataSolicitada          DateTime         @default(now()) @map("data_solicitada")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  ImagensManutencao     ImagemManutencao[]
  LaboratorioManutencao Laboratorio        @relation(fields: [laboratorioId], references: [id])
  UsuarioSolicitou      Usuario            @relation("UsuarioSolicitou", fields: [usuarioSolicitacaoId], references: [id])
  TecnicoResponsavel    Usuario            @relation("TecnicoResponsavel", fields: [tecnicoResponsavelId], references: [id])

  @@map("manutencoes")
}

model ImagemManutencao {
  id           Int    @id @default(autoincrement())
  manutencaoId Int    @map("manutencao_id")
  url          String
  nome         String

  ManutencaoRetratada Manutencao @relation(fields: [manutencaoId], references: [id])

  @@unique([nome, manutencaoId])
  @@map("imagens_manutencao")
}

enum CargoEnum {
  PROFESSOR
  COORDENADOR
  TECNICO
}

enum TipoManutencao {
  PREVENTIVA
  CORRETIVA
}

enum StatusManutencao {
  SOLICITADA
  CANCELADA
  CONCLUIDA
  PENDENTE
}
